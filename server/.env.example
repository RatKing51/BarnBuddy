NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

DATABASE_URL=
# Used only for CLI migrations running outside Railway's private network.
DATABASE_PUBLIC_URL=
USE_PUBLIC_DATABASE_URL=false
PGUSER=postgres
PGHOST=localhost
PGDATABASE=BarnBuddy
PGPASSWORD=password
PGPORT=5432

CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
CLERK_PREMIUM_PLAN_SLUG=premium
CLERK_PREMIUM_FEATURE_SLUG=premium_access

EMAIL_ENABLED=false
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=BarnBuddy <notifications@barnbuddy.pro>
RESEND_NOTIFICATIONS_FROM_EMAIL=BarnBuddy Notifications <notifications@barnbuddy.pro>
RESEND_NEWSLETTER_AUDIENCE_ID=aud_replace_me
CONTACT_TO_EMAIL=barnbuddyapp@gmail.com
EMAIL_TEST_ALLOWED_EMAILS=you@example.com
EMAIL_TEST_ALLOWED_CLERK_IDS=user_replace_me
NOTIFICATION_CRON_SECRET=replace_me_with_a_long_random_value

# Cloudflare R2 bucket. Animal photos stay private; site/* objects may use a public custom domain.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=barnbuddy-animal-photos
# Separate bucket for public website and admin images.
R2_SITE_BUCKET_NAME=barnbuddy-site-media
R2_SIGNED_URL_TTL_SECONDS=900
# Optional public R2 custom domain, for example https://media.barnbuddy.pro
R2_PUBLIC_BASE_URL=

# Comma-separated account allowlist for /admin website content editing.
ADMIN_EMAILS=you@example.com
ADMIN_CLERK_USER_IDS=user_replace_me
